{
  "name": "nx-oxfmt",
  "version": "0.3.0",
  "description": "Nx plugin for oxfmt - the high-performance Rust-powered code formatter",
  "keywords": [
    "formatter",
    "nx",
    "nx-plugin",
    "oxc",
    "oxfmt"
  ],
  "license": "MIT",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./plugin": "./dist/plugin.js",
    "./package.json": "./package.json",
    "./generators.json": "./generators.json",
    "./executors.json": "./executors.json",
    "./migrations.json": "./migrations.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@nx/devkit": "^22.5.4",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@nx/js": "^22.5.4",
    "@nx/plugin": "^22.5.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "nx": ">=20.0.0",
    "oxfmt": ">=0.30.0"
  },
  "executors": "./executors.json",
  "generators": "./generators.json",
  "nx-migrations": {
    "migrations": "./migrations.json"
  }
}
