{
  "name": "nx-oxfmt",
  "version": "0.2.0",
  "description": "Nx plugin for oxfmt - the high-performance Rust-powered code formatter",
  "keywords": [
    "formatter",
    "nx",
    "nx-plugin",
    "oxc",
    "oxfmt"
  ],
  "license": "MIT",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@nx/devkit": "^20.0.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@nx/js": "^20.0.0",
    "@nx/plugin": "^20.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "nx": ">=20.0.0",
    "oxfmt": ">=0.30.0"
  },
  "executors": "./executors.json",
  "generators": "./generators.json"
}
