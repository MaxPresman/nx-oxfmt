{
  "$schema": "https://json-schema.org/schema",
  "cli": "nx",
  "title": "Initialize Oxfmt",
  "description": "Initialize oxfmt in the workspace",
  "type": "object",
  "properties": {
    "skipInstall": {
      "type": "boolean",
      "default": false,
      "description": "Skip installing the oxfmt package"
    },
    "migratePrettier": {
      "type": "boolean",
      "default": false,
      "description": "Migrate existing Prettier configuration to oxfmt",
      "x-priority": "important"
    },
    "oxfmtVersion": {
      "type": "string",
      "default": "latest",
      "description": "Version of oxfmt to install"
    },
    "formatTargetName": {
      "type": "string",
      "default": "format",
      "description": "Name of the format target"
    },
    "checkTargetName": {
      "type": "string",
      "default": "format-check",
      "description": "Name of the format-check target"
    }
  },
  "additionalProperties": false
}
